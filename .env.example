# MQTT broker — typically your Home Assistant host running the Mosquitto
# broker add-on, or a standalone MQTT broker on your LAN.
# Use the broker's hostname/IP. On Home Assistant OS the default is
# `homeassistant.local`; with the Mosquitto add-on it may also be reachable
# as `core-mosquitto`. See README for HA setup steps.
MQTT_HOST=homeassistant.local
MQTT_PORT=1883
MQTT_USER=
MQTT_PASS=
MQTT_CLIENT_ID=ccusage-mqtt
MQTT_DISCOVERY_PREFIX=homeassistant
MQTT_BASE_TOPIC=claude_code_usage

# Friendly name shown in Home Assistant. If you run multiple ccusage-mqtt
# instances against different Claude Code accounts on the same broker, give
# each a distinct device name (and a distinct MQTT_BASE_TOPIC + MQTT_CLIENT_ID).
MQTT_DEVICE_NAME=Claude Code Usage

# Optional. When set, every state payload includes "account": "<name>", and
# HA exposes it as an attribute on each sensor entity. Useful for tagging
# multiple instances ("work", "personal", etc.).
ACCOUNT_NAME=

# Path on the host to the Claude Code config dir for this instance. Default
# is ~/.claude (single-account install). For a second instance, create a
# separate login directory first:
#   CLAUDE_CONFIG_DIR=~/.claude-work claude login
# then set this to that path.
CLAUDE_CONFIG_HOST_PATH=

# Claude Code OAuth (probe request for ratelimit headers).
# Default path inside the container; docker-compose bind-mounts ~/.claude
# from the host to /data/claude-projects, so .credentials.json lives there.
# The publisher re-reads on each poll so Claude Code's auto-refresh propagates.
CLAUDE_CREDENTIALS_PATH=/data/claude-projects/.credentials.json
ANTHROPIC_API_BASE=https://api.anthropic.com
PROBE_MODEL=claude-haiku-4-5-20251001

# ccusage subprocess
CCUSAGE_PROJECTS_DIR=/data/claude-projects

# Polling cadences (seconds)
HEADER_POLL_SEC=60
CCUSAGE_POLL_SEC=30

# Burn-rate ring buffer (Pro/Max mood classifier — %/min thresholds)
BURN_RATE_WINDOW_SEC=240
MOOD_IDLE_BELOW=0.10
MOOD_NORMAL_BELOW=0.20
MOOD_ACTIVE_BELOW=0.33

# Token-rate mood classifier (used on Enterprise plans where session_pct is
# stuck at 0 until you blow past base allocation). Thresholds in tokens/hour.
MOOD_TOKENS_IDLE_BELOW=500
MOOD_TOKENS_NORMAL_BELOW=2500
MOOD_TOKENS_ACTIVE_BELOW=10000

LOG_LEVEL=INFO
